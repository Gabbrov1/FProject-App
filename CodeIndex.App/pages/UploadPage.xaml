<UserControl x:Class="CodeIndex.App.UploadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Style="{StaticResource MainGrid}">
        <StackPanel Margin="20">
            <TextBlock Text="JSON Files in temp/" Style="{StaticResource Heading1}"/>
            
            <CheckBox x:Name="SelectAllCheckBox" Content="Select All" Foreground="{StaticResource TextColor}" Margin="0,0,0,10" Checked="SelectAllCheckBox_Checked" Unchecked="SelectAllCheckBox_Unchecked"/>
            
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                <ListBox x:Name="JsonFilesList" Height="300" Background="{StaticResource BackgroundColor}" BorderThickness="0" Foreground="{StaticResource TextColor}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding FileName}" IsChecked="{Binding IsSelected}" Click="FileCheckBox_Click" Foreground="{StaticResource TextColor}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            
            <TextBlock x:Name="StatusText" Text="Loading files..." Style="{StaticResource TextStyle}" Foreground="{StaticResource SecondaryTextColor}"/>
        </StackPanel>

        <StackPanel>
            <Button x:Name="UploadButton"
                        Content="Upload"
                        Width="120"
                        Height="30"
                        Style="{StaticResource ButtonStyle}"
                        Click="UploadButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>