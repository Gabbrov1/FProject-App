<UserControl 
    x:Class="CodeIndex.App.HomeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    >
    <Grid>
        <Grid VerticalAlignment="Top" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title + Logo Row -->
            <StackPanel
                Grid.Row="0"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,10,0,0">

                <TextBlock
                    Text="Code"
                    Style="{StaticResource AppTitle}"
                    Foreground="{StaticResource AppNameColor}"/>
                <TextBlock
                    Text="Index"
                    Style="{StaticResource AppTitle}"
                    Foreground="{StaticResource AppNameColor2}"
                    />

                <Image
                    Source="/Assets/logo.png" 
                    Style="{StaticResource AppLogo}" 
                    />
            </StackPanel>
            
            <TextBlock Grid.Row="2"
                        Text="Your personal code snippet manager"
                        Style="{StaticResource TextStyle}"
                        HorizontalAlignment="Center"
                    />
        </Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="FilePathTextBox"
                Margin="0,0,10,0"
                Width="400"
                Height="30"
                IsReadOnly="True"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border
                    Style="{StaticResource CardBorder}"
                    >
                    <Button x:Name="SelectFileButton"
                        Content="Select File"
                        Width="120"
                        Height="30"
                        Style="{StaticResource ButtonStyle}"
                        Click="SelectFile_Click"/>
                </Border>

                <Border
                    x:Name="CancelButton"
                    Visibility="Collapsed"
                    Style="{StaticResource CardBorder}"
                    >
                    <Button
                        Content="Cancel"
                        Width="120"
                        Height="30"
                        Style="{StaticResource ButtonStyle}"
                        Click="CancelButton_Click"/>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>