<UserControl 
    x:Class="CodeIndex.App.homeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    >
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="CodeIndex"
                        FontSize="36"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,10"
                        Visibility="Collapsed"
                        />
            
            <Image
                Margin = "0,20,0,10"
                Width  = "140"
                Height = "60"
                Source = "Images/logo.png"
            >
            
            </Image>
            
            <TextBlock Text="Your personal code snippet manager"
                        FontSize="16"
                        HorizontalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="FilePathTextBox"
                Margin="0,0,10,0"
                Width="400"
                Height="30"
                IsReadOnly="True"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="LightGray"
                    Padding="2"
                    >
                    <Button x:Name="SelectFileButton"
                        Content="Select File"
                        Width="120"
                        Height="30"
                        Click="SelectFile_Click"/>
                </Border>

                <Border
                    x:Name="CancelButton"
                    Visibility="Collapsed"
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="LightGray"
                    Padding="2"
                    >
                    <Button
                        Content="Cancel"
                        Width="120"
                        Height="30"
                        Click="CancelButton_Click"/>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>