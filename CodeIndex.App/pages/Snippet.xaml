<UserControl x:Class="CodeIndex.App.SnippetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             >
    <Grid Margin="16"
        Style="{StaticResource MainGrid}"
        >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
            Style="{StaticResource CardBorder}"
            Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                            Text="Snippet:" 
                            Style="{StaticResource TextStyle}"
                           />

                <ComboBox Grid.Column="1" 
                          x:Name="SnippetCombo" 
                          VerticalAlignment="Center" 
                          Padding="8,6"
                          SelectionChanged="SnippetCombo_SelectionChanged"/>

                <Button Grid.Column="2" 
                        Content="Refresh" 
                        Margin="12,0,0,0" 
                        Padding="20,6" 
                        Style="{StaticResource ButtonStyle}"
                        Click="RefreshSnippets_ClickAsync"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                Style="{StaticResource CardBorder}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="CodeDisplay" 
                           Text="Select a snippet to display code..." 
                           TextWrapping="NoWrap"
                           Style="{StaticResource TextStyle}"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>