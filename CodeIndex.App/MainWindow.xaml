<Window x:Class="CodeIndex.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CodeIndex.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="CodeIndex"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,10"/>
            <TextBlock Text="Your personal code snippet manager"
                       FontSize="16"
                       HorizontalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="FilePathTextBox"
                Margin="0,0,10,0"
                Width="400"
                Height="30"
                IsReadOnly="True"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="LightGray"
                    Padding="2"
                    >
                    <Button x:Name="SelectFileButton"
                        Content="Select File"
                        Width="120"
                        Height="30"
                        Click="SelectFile_Click"/>
                </Border>

                <Border
                    x:Name="CancelButton"
                    Visibility="Collapsed"
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="LightGray"
                    Padding="2"
                    >
                    <Button
                        Content="Cancel"
                        Width="120"
                        Height="30"
                        Click="CancelButton_Click"/>
                </Border>
            </StackPanel>
        </StackPanel>        
    </Grid>
</Window>
