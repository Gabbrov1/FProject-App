<Window x:Class="CodeIndex.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CodeIndex.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Grid.Style>
            <StaticResource ResourceKey="MainGrid"/>
        </Grid.Style>

        <Grid Grid.Row="0" Style="{StaticResource MainGrid}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <Button Content="Home" Style="{StaticResource NavButton}" Click="HomeMenu_Click"/>
                <Button Content="Upload" Style="{StaticResource NavButton}" Click="UploadMenu_Click"/>
                
            </StackPanel>
        </Grid>
        

        <Grid x:Name="Snippet" Grid.Row="1" Style="{StaticResource MainGrid}">
            <ContentControl x:Name="MainContent"/>
        </Grid>
    </Grid>
</Window>
