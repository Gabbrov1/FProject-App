<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors (like CSS variables) -->
    <SolidColorBrush x:Key="BackgroundColor">#161B22</SolidColorBrush>
    <SolidColorBrush x:Key="ForegroundColor">#E6EDF3</SolidColorBrush>
    <SolidColorBrush x:Key="BorderColor">#30363D</SolidColorBrush>
    <SolidColorBrush x:Key="AccentColor">#79C0FF</SolidColorBrush>
    <SolidColorBrush x:Key="SuccessColor">#238636</SolidColorBrush>
    <SolidColorBrush x:Key="SecondaryTextColor">#8B949E</SolidColorBrush>
    <SolidColorBrush x:Key="HoverColor">#21262D</SolidColorBrush>

    <SolidColorBrush x:Key="TextColor">#E6EDF3</SolidColorBrush>

    <SolidColorBrush x:Key="ButtonColor">#21262D</SolidColorBrush>
    <SolidColorBrush x:Key="ButtonHoverColor">#30363D</SolidColorBrush>

    <!-- AppName and Logo -->
    <SolidColorBrush x:Key="AppNameColor">#79C0FF</SolidColorBrush>
    <SolidColorBrush x:Key="AppNameColor2">#ff8c1a</SolidColorBrush>


    <Style TargetType="TextBlock" x:Key="AppTitle">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="40"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- App Image Logo Style -->
    <Style TargetType="Image" x:Key="AppLogo">
        <Setter Property="Width" Value="140"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="Margin" Value="0,20,0,10"/>
    </Style>

    <!-- General Text Style -->
    <Style TargetType="TextBlock" x:Key="TextStyle">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
    </Style>

    <Style TargetType="TextBox" x:Key="TextBoxStyle">
        <Setter Property="FontFamily" Value= "Segoe UI"/>
        <Setter Property="FontSize" Value= "12"/>
        <Setter Property="Foreground" Value= "{StaticResource TextColor}"/>  
    </Style>
        
    <!-- Main Window Style -->
    <Style TargetType="Grid" x:Key="MainGrid">
        <Setter Property="Background" Value="{StaticResource BackgroundColor}"/>
    </Style>

    <!-- Border Styles -->
    <Style TargetType="Border" x:Key="CardBorder">
        <Setter Property="Background" Value="{StaticResource BackgroundColor}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <!-- Headings Styles -->
        <Style TargetType="TextBlock" x:Key="Heading1">
            <Setter Property="FontSize" Value="38"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="Heading2">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

    
    <!--Nav Button Style -->
    <Style TargetType="Button" x:Key="NavButton">
        <Setter Property="Background" Value="{StaticResource BackgroundColor}"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5,0"/>
    </Style>

    <!-- Button Style -->
    <Style TargetType="Button" x:Key="ButtonStyle">
        <Setter Property="Background" Value="{StaticResource ButtonColor}"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ButtonHoverColor}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                <Setter Property="Foreground" Value="#824262"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>